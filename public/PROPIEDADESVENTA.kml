			<coordinates>-71.30014676797302,-40.13506679782964,725.4636189851171</coordinates>
		</Point>
	</Placemark>
<Placemark id="05676F7F583612FE86BD">
		<name>HUILQUIL CASONA DE MONTAÑA</name>
		<description><![CDATA[<div>CASA TURISTICA PARA 10712 PAX<br></div><div>Valor temporada 2025<br></div><div>U$d 570 baja&nbsp;<br></div><div>600 media<br></div><div>650 alta<br></div><div><br></div><div>Abre el 4 de ABRIL//<br></div>]]></description>
